@inject IInvoiceUploaderInvoker _invoiceUploaderInvoker
@inject ClipboardService _clipboard

<MudDialog>
    <DialogContent>
        <ResponseMessage Token="_token" @ref="_responseMessage" />

        @if (_randomInvoice != null)
        {
            <MudGrid>
                <MudItem xs="11">
                    <MudTextField Value="_randomInvoice.Header" Lines="4" />
                </MudItem>
                <MudItem xs="1">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="CopyToClipboardHeader" />
                </MudItem>
                <MudItem xs="11">
                    <MudTextField Value="_randomInvoice.Detail" Lines="10" />
                </MudItem>
                <MudItem xs="1">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="CopyToClipboardDetail" />
                </MudItem>
            </MudGrid>
            
        }
    </DialogContent>
    <DialogActions>
        @if (Disabled())
        {
            <MudProgressLinear Indeterminate="true" />
        }
        <MudButton OnClick="OnGetRandom" Disabled="Disabled()" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">Go</MudButton>
        <MudButton onclick="Close" Disabled="Disabled()" Size="Size.Small">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
        [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }
    private BroadcastToken _token = new();
    private StandByControls _standBy = new();
    private Controls _controls = new();
    private RandomInvoiceDTO? _randomInvoice;
    private ResponseMessage? _responseMessage;

    protected override void OnInitialized()
    {
        _standBy.RegisterControl(_controls.ControlAll, _token);
    }

    private async Task OnGetRandom()
    {
        var result = await _invoiceUploaderInvoker.GetRandom(_token);
        if (result.IsSuccess && result.Obj != null)
        {
            _randomInvoice = result.Obj;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CopyToClipboardHeader()
    {
        if (_randomInvoice != null)
        {
            await _clipboard.WriteTextAsync(_randomInvoice.Header);
            if (_responseMessage != null)
            {
                _responseMessage.SendMessage("Header copied to clipboard", Severity.Normal);
            }
        }
    }

    private async Task CopyToClipboardDetail()
    {
        if (_randomInvoice != null)
        {
            await _clipboard.WriteTextAsync(_randomInvoice.Detail);
            if (_responseMessage != null)
            {
                _responseMessage.SendMessage("Detail copied to clipboard", Severity.Normal);
            }
        }
    }

    private bool Disabled()
    {
        return _standBy.Disabled(_controls.ControlAll);
    }

    private void Close()
    {
        if (MudDialog != null)
        {
            MudDialog.Close();
        }
    }

    private record Controls(
        string ControlAll = "ControlAll"
    );
}
