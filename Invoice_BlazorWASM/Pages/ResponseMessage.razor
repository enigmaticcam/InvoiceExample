@inject ISnackbar _snackBar

@code {
    [Parameter, EditorRequired]
    public BroadcastToken Token { get; set; }

    protected override void OnInitialized()
    {
        Token.OnComplete += GetMessage;
    }

    private Task GetMessage(List<BlazorResult> responses)
    {
        var messages = responses
            .Where(x => !string.IsNullOrEmpty(x.Message))
            .ToList();
        foreach (var message in messages)
        {
            if (message.IsSuccess)
            {
                _snackBar.Add(message.Message, Severity.Normal);
            }
            else
            {
                _snackBar.Add(message.Message, Severity.Error);
            }
        }
        return Task.CompletedTask;
    }

    public void SendMessage(string message, Severity severity)
    {
        _snackBar.Add(message, severity);
    }
}